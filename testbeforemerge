# Helper Functions
def get_floor(location, location1f, location2f, location3f, locationclubs1f, locationclubs2f, locationclubs3f, locationroof)
  return "1F" if (location1f + locationclubs1f).include?(location)
  return "2F" if (location2f + locationclubs2f).include?(location)
  return "3F" if (location3f + locationclubs3f).include?(location)
  return "Roof" if locationroof.include?(location)
  nil
end

def get_current_floor_locations(player_floor, location1f, location2f, location3f, locationclubs1f, locationclubs2f, locationclubs3f, locationroof)
  case player_floor
  when "1F"
    location1f + locationclubs1f
  when "2F"
    location2f + locationclubs2f
  when "3F"
    location3f + locationclubs3f
  when "Roof"
    locationroof
  end
end

def can_move_to?(location, player_floor, location1f, location2f, location3f, locationclubs1f, locationclubs2f, locationclubs3f, locationroof)
  current_locations = get_current_floor_locations(player_floor, location1f, location2f, location3f, locationclubs1f, locationclubs2f, locationclubs3f, locationroof)
  current_locations.include?(location)
end

