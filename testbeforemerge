      puts ""
    else
      puts "You can't go there! That location is not on #{player_floor}."
      puts "Type 'checkfloormap' to see available locations on your current floor."
      puts ""
    end

  elsif input == "stairs"
    puts "Go up or down?"
    stairs_direction = gets.chomp.downcase
    if stairs_direction == "up"
      player_floor = go_upstairs(player_floor)
      player_location = get_current_floor_locations(player_floor, location1f, location2f, location3f, locationclubs1f, locationclubs2f, locationclubs3f, locationroof).first
      puts "You are now at: #{player_location}"
      puts ""
    elsif stairs_direction == "down"
      player_floor = go_downstairs(player_floor)
      player_location = get_current_floor_locations(player_floor, location1f, location2f, location3f, locationclubs1f, locationclubs2f, locationclubs3f, locationroof).first
      puts "You are now at: #{player_location}"
      puts ""
    else
      puts "Invalid direction!"
      puts ""
    end

  elsif input == "checkfloormap"
    current_locations = get_current_floor_locations(player_floor, location1f, location2f, location3f, locationclubs1f, locationclubs2f, locationclubs3f, locationroof)
    puts "=== #{player_floor} Locations ==="
    current_locations.each_with_index do |location, index|
      puts "#{index + 1}. #{location}"
    end
    puts "====================="
    puts ""

  elsif input == "debug"
    puts "=== DEBUG INFO ==="
    puts "Current Location: #{player_location}"
    puts "Current Floor: #{player_floor}"
    puts "Students: #{students.keys.join(", ")}"
    puts "==================="
    puts ""

  elsif input.start_with?("talk to ")
    npc_name = input.sub("talk to ", "").strip
